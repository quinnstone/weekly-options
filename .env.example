# Finnhub (https://finnhub.io - free tier)
FINNHUB_API_KEY=your_finnhub_key

# FRED (https://fred.stlouisfed.org/docs/api/api_key.html - free)
FRED_API_KEY=your_fred_key

# Reddit (https://www.reddit.com/prefs/apps - free, optional)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=ZeroDTE/1.0

# Discord Webhook (create in Discord channel settings)
DISCORD_WEBHOOK_URL=your_webhook_url

# NewsAPI (https://newsapi.org - free tier, optional)
NEWS_API_KEY=your_newsapi_key
